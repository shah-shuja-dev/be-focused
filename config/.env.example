# ── Work schedule ────────────────────────────────────────────────
WORK_DAYS=mon,tue,wed,thu,fri
WORK_START=09:00
WORK_END=18:00

# How often to run a check window (seconds)
# 3600=hourly  1800=every 30min  900=every 15min
CHECK_INTERVAL=3600

# How long each check window lasts (seconds)
# Camera opens, model runs, then camera closes again
CHECK_WINDOW_DURATION=60

# ── Violation detection ──────────────────────────────────────────
BUFFER_SECS=30

# Seconds between frames inside a check window
# 2 = grab one frame every 2s — very lightweight
INFERENCE_INTERVAL=2

# ── Audio ────────────────────────────────────────────────────────
# on_violation | periodic | both
TRIGGER_MODE=on_violation
REMINDER_INTERVAL_SECS=3600
# motivational | stern | funny
QUOTE_STYLE=motivational
# pyttsx3 | coqui
TTS_ENGINE=pyttsx3

# ── MLflow ───────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=focus_classifier
MODEL_NAME=FocusClassifier

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000